# Stage 1: Build the Go engine for Windows
FROM golang:alpine AS engine-builder
WORKDIR /src
# Copy engine source
COPY engine/ /src/engine/
WORKDIR /src/engine
RUN apk add --no-cache git
RUN GOOS=windows GOARCH=amd64 go build -o pvpn-engine.exe helper.go setup_windows.go

# Stage 2: Package the Python CLI with PyInstaller using PyWine
FROM tobix/pywine:3.11 AS pyinstaller-builder
WORKDIR /app

# Copy the entire project
COPY . .
# Overwrite/Add the compiled Windows engine from Stage 1
COPY --from=engine-builder /src/engine/pvpn-engine.exe engine/pvpn-engine.exe

# Install dependencies and build the standalone .exe
RUN wine pip install pyinstaller && \
    wine pip install -r requirements.txt && \
    wine pyinstaller --onefile \
        --name pvpn-next-windows \
        --icon=icon.ico \
        --version-file version_info.txt \
        --add-data "engine/pvpn-engine.exe;engine" \
        --add-data "engine/wintun.dll;engine" \
        pvpn-next

# Stage 3: Export the final binary to the host
FROM scratch AS export-stage
COPY --from=pyinstaller-builder /app/dist/pvpn-next-windows.exe /
