    if getattr(sys, 'frozen', False):
        base_dir = sys._MEIPASS
    else:
        base_dir = os.path.dirname(os.path.realpath(__file__))
        
    engine_name = "pvpn-engine.exe" if platform.system() == "Windows" else "pvpn-engine"
