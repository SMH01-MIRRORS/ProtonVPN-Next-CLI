    awg_params = parse_awg_string(final_awg_str) if final_awg_str else {}
    
    config_lines = [
        "[Interface]",
        f"PrivateKey = {private_key}",
        "Address = 10.2.0.2/32"
    ]
    
    # DNS configuration
