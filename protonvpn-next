def get_config_dir() -> str:
    if platform.system() == "Windows":
        base = os.environ.get("APPDATA", os.path.expanduser("~"))
        d = os.path.join(base, "protonvpn-next")
    else:
        d = os.path.expanduser("~/.config/protonvpn-next")
    os.makedirs(d, exist_ok=True)
    return d

